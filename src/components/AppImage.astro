---
import { Image } from 'astro:assets';
import type { ComponentProps } from 'astro/types';

type Props = ComponentProps<typeof Image> & { caption: string };

const { class: className, loading = 'lazy', caption, ...rest } = Astro.props;
---

<figure class="flex flex-col items-center">
  <Image class:list={['rounded-lg', className]} loading={loading} {...rest} />
  <figcaption class="self-end">{caption}</figcaption>
</figure>
